<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calculadora de Média EaD"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Campo Nota A1 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nota A1 (0-10)"/>
    <EditText
        android:id="@+id/editTextA1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="Digite a nota A1"/>

    <!-- Campo Nota A2 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nota A2 (0-10)"
        android:layout_marginTop="16dp"/>
    <EditText
        android:id="@+id/editTextA2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="Digite a nota A2"/>

    <!-- Campo Nota A3 (Opcional) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nota A3 (0-10) - Opcional"
        android:layout_marginTop="16dp"/>
    <EditText
        android:id="@+id/editTextA3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="Digite a nota A3 (se houver)"/>

    <!-- Botão Calcular -->
    <Button
        android:id="@+id/buttonCalcular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CALCULAR MÉDIA"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/purple_500"/>

    <!-- Resultado -->
    <TextView
        android:id="@+id/textViewResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:text="Sua média aparecerá aqui"/>

</LinearLayout>